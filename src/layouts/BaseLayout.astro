---
import "../styles/global.css"

interface Props {
  title?: string
  description?: string
}

const {
  title = "Gray's Mobile Mechanics LLC | We Come to You — VT & NH",
  description = "Mobile mechanic & small engine repair in Orange, VT serving Vermont and New Hampshire. Vehicles, ATVs, mowers, snowblowers & generators. Open 24/7. Call 802-359-3156.",
} = Astro.props

// Canonical NAP (name, address, phone) — keep this in sync with Nav, Footer,
// About, and Contact if any of it ever changes.
// TODO: replace SITE_URL with the live domain once it's registered/deployed.
const SITE_URL = "https://graysmobilemechanics.com"
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  name: "Gray's Mobile Mechanics LLC",
  image: `${SITE_URL}/images/logo.webp`,
  url: SITE_URL,
  telephone: "+18023593156",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Orange",
    addressRegion: "VT",
    addressCountry: "US",
  },
  areaServed: [
    { "@type": "State", name: "Vermont" },
    { "@type": "State", name: "New Hampshire" },
  ],
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday",
    ],
    opens: "00:00",
    closes: "23:59",
  },
  sameAs: ["https://www.facebook.com/share/1Gbcrma3Tv/"],
}
---

<!doctype html>
<html lang="en" class="bg-ink">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d0d0f" />
    <link rel="icon" type="image/jpeg" href="/images/logo.webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  </head>
  <body class="bg-paper text-ink">
    <a href="#main" class="skip-link rounded-md bg-brand px-4 py-2 text-sm font-600 text-paper">
      Skip to main content
    </a>
    <slot />
  </body>
</html>
