---
// Real reviews from Gray's Mobile Mechanics customers (Facebook & text).
const testimonials = [
  {
    quote:
      "If you are looking for quality services right at your door, Morgan is your guy! Fixed my son's dirtbike and maintained my car!!!",
    name: "Rayanne Vesper",
    location: "Facebook Review",
  },
  {
    quote:
      "Highly recommend! Is willing to do just about whatever it takes to get the job done! Thank you Morgan!",
    name: "Mariah Potwin",
    location: "Facebook Review",
  },
  {
    quote:
      "I had a lawn mower that had been through a flood. After months of trying to figure out what to do with it, I decided to get a professional opinion, so I called Gray's Mobile Mechanics. Morgan came over and had that thing purring in fifteen minutes. It didn't even sputter or stall out. Thorough and talented — this guy knows how to fix it.",
    name: "Thaddeus Wildasin",
    location: "Customer Testimonial",
  },
]
---

<section id="testimonials" class="bg-paper py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="font-display text-sm font-600 uppercase tracking-[0.3em] text-brand-dark">Testimonials</span>
      <h2 class="mt-3 font-display text-4xl font-700 uppercase leading-tight tracking-tight text-balance sm:text-5xl">
        What our neighbors say
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-steel text-pretty">
        Real reviews from VT &amp; NH customers.
      </p>
    </div>

    <div class="mx-auto mt-14 max-w-3xl divide-y divide-ink/10">
      {
        testimonials.map((t) => (
          <figure class="flex flex-col items-center py-10 text-center first:pt-0 last:pb-0">
            <div class="flex gap-1 text-brand" aria-hidden="true">
              {Array.from({ length: 5 }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
              ))}
            </div>
            <blockquote class="mt-5 max-w-2xl text-lg leading-relaxed text-steel text-balance">
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <figcaption class="mt-6 flex flex-col items-center leading-tight">
              <span class="font-600 text-ink">{t.name}</span>
              <span class="text-sm text-steel">{t.location}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
