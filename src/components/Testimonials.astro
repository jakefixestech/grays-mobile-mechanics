---
// Placeholder testimonials — swap `quote`, `name`, and `location` with real
// reviews from Facebook or new customers when available.
const testimonials = [
  {
    quote:
      "Your review could go here. Add a real customer quote about how convenient and honest the service was.",
    name: "Customer Name",
    location: "Vermont",
  },
  {
    quote:
      "Placeholder for a testimonial about a roadside or driveway repair. Highlight the come-to-you convenience.",
    name: "Customer Name",
    location: "New Hampshire",
  },
  {
    quote:
      "Space for a review about small engine or seasonal equipment work. Mention fair pricing and quick turnaround.",
    name: "Customer Name",
    location: "Orange, VT",
  },
]
---

<section id="testimonials" class="bg-paper py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="font-display text-sm font-600 uppercase tracking-[0.3em] text-brand">Testimonials</span>
      <h2 class="mt-3 font-display text-4xl font-700 uppercase leading-tight tracking-tight text-balance sm:text-5xl">
        What our neighbors say
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-steel text-pretty">
        Real reviews from VT &amp; NH customers coming soon. Here&apos;s where they&apos;ll live.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        testimonials.map((t) => (
          <figure class="flex h-full flex-col rounded-2xl border border-ink/10 bg-cloud/60 p-7">
            <div class="flex gap-1 text-brand">
              {Array.from({ length: 5 }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
              ))}
            </div>
            <blockquote class="mt-4 flex-1 text-base leading-relaxed text-steel">
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <figcaption class="mt-6 flex items-center gap-3 border-t border-ink/10 pt-5">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand font-display text-sm font-700 text-paper">
                {t.name.charAt(0)}
              </span>
              <span class="flex flex-col leading-tight">
                <span class="font-600 text-ink">{t.name}</span>
                <span class="text-sm text-steel">{t.location}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
