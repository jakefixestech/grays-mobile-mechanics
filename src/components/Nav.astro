---
const links = [
  { label: "Home", href: "#home" },
  { label: "About", href: "#about" },
  { label: "Services", href: "#services" },
  { label: "Pricing", href: "#pricing" },
  { label: "Testimonials", href: "#testimonials" },
  { label: "Contact", href: "#contact" },
]
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-ink/90 backdrop-blur">
  <nav class="mx-auto flex h-20 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <a href="#home" class="flex items-center gap-3">
      <img
        src="/images/logo.png"
        alt="Gray's Mobile Mechanics logo"
        width="44"
        height="44"
        class="h-11 w-11 rounded-full ring-1 ring-white/15"
      />
      <span class="flex flex-col leading-none">
        <span class="font-display text-lg font-700 uppercase tracking-wide text-paper">Gray&apos;s Mobile</span>
        <span class="font-display text-xs font-600 uppercase tracking-[0.35em] text-brand">Mechanics LLC</span>
      </span>
    </a>

    <div class="hidden items-center gap-8 lg:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm font-500 text-fog transition-colors hover:text-paper"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-3">
      <a
        href="tel:8023593156"
        class="hidden items-center gap-2 text-sm font-600 text-paper sm:flex"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-brand"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        802-359-3156
      </a>
      <a
        href="#contact"
        class="rounded-md bg-brand px-4 py-2 text-sm font-600 text-paper shadow-sm transition-colors hover:bg-brand-dark"
      >
        Book Now
      </a>
    </div>
  </nav>
</header>
