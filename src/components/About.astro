---
const points = [
  {
    title: "We come to you",
    body: "Home, workplace, or roadside — you don't move a thing. We bring the shop to your driveway across Vermont and New Hampshire.",
  },
  {
    title: "Honest, fair pricing",
    body: "Clear communication and straight answers. No upsells, no surprises — just the work you actually need, done right.",
  },
  {
    title: "Trusted for years",
    body: "Two-plus years serving VT & NH neighbors of every age — anyone who needs a repair, maintenance, or a second opinion.",
  },
]
---

<section id="about" class="bg-paper py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-14 lg:grid-cols-2">
      <div class="relative">
        <img
          src="/images/small-engine.png"
          alt="Mechanic repairing a small engine at a workbench"
          class="aspect-4/3 w-full rounded-2xl object-cover shadow-xl"
        />
        <div class="absolute -bottom-6 -right-4 hidden rounded-xl bg-brand px-6 py-5 text-paper shadow-lg sm:block">
          <p class="font-display text-3xl font-700 leading-none">Orange, VT</p>
          <p class="mt-1 text-sm text-paper">Locally owned &amp; operated</p>
        </div>
      </div>

      <div>
        <span class="font-display text-sm font-600 uppercase tracking-[0.3em] text-brand">About Us</span>
        <h2 class="mt-3 font-display text-4xl font-700 uppercase leading-tight tracking-tight text-balance sm:text-5xl">
          Reliable repair, brought to your door
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-steel text-pretty">
          Gray&apos;s Mobile Mechanics LLC is owned and run by Morgan Gray, a mobile
          mechanic serving Vermont and New Hampshire. Whether it&apos;s a vehicle that
          won&apos;t start, a mower that quit mid-season, or routine maintenance you&apos;d
          rather not haul in for — we handle it wherever you are.
        </p>

        <div class="mt-8 grid gap-4">
          {
            points.map((point) => (
              <div class="flex gap-4 rounded-xl border border-ink/10 bg-cloud/60 p-5">
                <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-brand text-paper">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><polyline points="20 6 9 17 4 12" /></svg>
                </div>
                <div>
                  <h3 class="font-display text-lg font-600 uppercase tracking-wide">{point.title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-steel">{point.body}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
