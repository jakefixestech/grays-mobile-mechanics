---
---

<section id="home" class="relative overflow-hidden bg-ink pt-20 text-paper">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="/images/hero-roadside.webp"
      alt="Mobile mechanic repairing a vehicle in a driveway"
      class="h-full w-full object-cover opacity-40"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/85 to-ink/40"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8 lg:py-36">
    <div class="grid items-center gap-12 lg:grid-cols-[1.3fr_0.7fr]">
    <div class="max-w-2xl">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-brand/40 bg-brand/10 px-4 py-1.5 text-xs font-600 uppercase tracking-[0.2em] text-brand-bright"
      >
        <span class="h-2 w-2 rounded-full bg-brand"></span>
        Open 24/7/365 · VT &amp; NH
      </span>

      <h1 class="mt-6 font-display text-5xl font-700 uppercase leading-[1.05] tracking-tight text-balance sm:text-6xl lg:text-7xl">
        We Come <span class="text-brand">to You.</span>
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-fog text-pretty">
        Expert mobile repair for vehicles, ATVs, and small engines, right in your
        driveway or at your workplace. No tow trucks, no waiting rooms. Just honest,
        capable service that shows up.
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row sm:items-center">
        <a
          href="#contact"
          class="inline-flex items-center justify-center gap-2 rounded-md bg-brand px-7 py-3.5 text-base font-600 text-paper shadow-lg shadow-brand/20 transition-colors hover:bg-brand-dark"
        >
          Book an Appointment
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
        <a
          href="tel:8023593156"
          class="inline-flex items-center justify-center gap-2 rounded-md border border-white/20 px-7 py-3.5 text-base font-600 text-paper transition-colors hover:bg-white/10"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-brand" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          802-359-3156
        </a>
      </div>

      <dl class="mt-14 grid max-w-md grid-cols-3 gap-6 border-t border-white/10 pt-8">
        <div>
          <dt class="text-xs uppercase tracking-wide text-fog">Availability</dt>
          <dd class="mt-1 font-display text-2xl font-700 text-paper">24/7</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wide text-fog">Service Area</dt>
          <dd class="mt-1 font-display text-2xl font-700 text-paper">VT / NH</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wide text-fog">In Business</dt>
          <dd class="mt-1 font-display text-2xl font-700 text-paper">2+ Yrs</dd>
        </div>
      </dl>
    </div>

    <div class="hidden justify-self-center lg:block">
      <img
        src="/images/logo.webp"
        alt="Gray's Mobile Mechanics logo for small engines, cars, ATVs, tractors and more, we come to you"
        class="w-full max-w-sm rounded-2xl shadow-2xl shadow-black/50"
      />
    </div>
    </div>
  </div>
</section>
