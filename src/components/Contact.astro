---
const services = [
  "Vehicle diagnostics & repair",
  "Oil change / maintenance",
  "Brake service",
  "Battery / starter / alternator",
  "Check engine light",
  "Lawn mower repair",
  "Snowblower repair",
  "Generator service",
  "ATV / small engine",
  "General troubleshooting",
  "Other",
]
---

<section id="contact" class="bg-ink py-20 text-paper sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-14 lg:grid-cols-2">
      <!-- Info side -->
      <div>
        <span class="font-display text-sm font-600 uppercase tracking-[0.3em] text-brand-bright">Contact</span>
        <h2 class="mt-3 font-display text-4xl font-700 uppercase leading-tight tracking-tight text-balance sm:text-5xl">
          Book an appointment
        </h2>
        <p class="mt-5 max-w-lg text-lg leading-relaxed text-fog text-pretty">
          Tell us what you&apos;re dealing with and where you are. We&apos;ll reach out to
          confirm a time that works — days, nights, weekends, or holidays.
        </p>

        <div class="mt-10 flex flex-col gap-5">
          <a href="tel:8023593156" class="group flex items-center gap-4">
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand/15 text-brand transition-colors group-hover:bg-brand group-hover:text-paper">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </span>
            <span class="flex flex-col leading-tight">
              <span class="text-xs uppercase tracking-wide text-fog">Call or text</span>
              <span class="font-display text-xl font-700">802-359-3156</span>
            </span>
          </a>

          <div class="flex items-center gap-4">
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand/15 text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </span>
            <span class="flex flex-col leading-tight">
              <span class="text-xs uppercase tracking-wide text-fog">Service area</span>
              <span class="font-display text-xl font-700">Vermont &amp; New Hampshire</span>
            </span>
          </div>

          <div class="flex items-center gap-4">
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand/15 text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </span>
            <span class="flex flex-col leading-tight">
              <span class="text-xs uppercase tracking-wide text-fog">Hours</span>
              <span class="font-display text-xl font-700">Open 24/7/365</span>
            </span>
          </div>
        </div>
      </div>

      <!-- Form side -->
      <div class="rounded-2xl border border-white/10 bg-ink-soft p-6 sm:p-8">
        <form
          id="appointment-form"
          name="appointment"
          class="flex flex-col gap-5"
        >
          <!-- Web3Forms: replace with the access key emailed from the client's Web3Forms account -->
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
          <input type="hidden" name="subject" value="New appointment request — Gray's Mobile Mechanics" />
          <input type="hidden" name="from_name" value="Gray's Mobile Mechanics Website" />
          <!-- Honeypot spam trap, must stay hidden from real visitors -->
          <label for="botcheck" class="hidden" style="display:none">Leave this field blank</label>
          <input id="botcheck" type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div class="grid gap-5 sm:grid-cols-2">
            <div class="flex flex-col gap-2">
              <label for="name" class="text-sm font-600 text-cloud">Name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder="Your name"
                class="rounded-md border border-white/10 bg-ink px-4 py-3 text-paper placeholder:text-fog/60 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="phone" class="text-sm font-600 text-cloud">Phone</label>
              <input
                id="phone"
                name="phone"
                type="tel"
                required
                autocomplete="tel"
                placeholder="(802) 000-0000"
                class="rounded-md border border-white/10 bg-ink px-4 py-3 text-paper placeholder:text-fog/60 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
              />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="email" class="text-sm font-600 text-cloud">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="you@example.com"
              class="rounded-md border border-white/10 bg-ink px-4 py-3 text-paper placeholder:text-fog/60 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="service" class="text-sm font-600 text-cloud">Service needed</label>
            <select
              id="service"
              name="service"
              class="rounded-md border border-white/10 bg-ink px-4 py-3 text-paper focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            >
              {services.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <label for="message" class="text-sm font-600 text-cloud">Message / details</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Tell us what's going on and your location (town/city)…"
              class="rounded-md border border-white/10 bg-ink px-4 py-3 text-paper placeholder:text-fog/60 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            ></textarea>
          </div>

          <button
            type="submit"
            id="appointment-submit"
            class="mt-1 inline-flex items-center justify-center gap-2 rounded-md bg-brand px-6 py-3.5 text-base font-600 text-paper transition-colors hover:bg-brand-dark disabled:cursor-not-allowed disabled:opacity-60"
          >
            <span id="appointment-submit-label">Request Appointment</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </button>

          <p
            id="appointment-status"
            class="hidden text-center text-sm"
            role="status"
            aria-live="polite"
          ></p>

          <p class="text-center text-xs text-fog">
            Prefer to talk? Call or text <a href="tel:8023593156" class="font-600 text-brand-bright hover:underline">802-359-3156</a> anytime.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("appointment-form") as HTMLFormElement | null
  const submitBtn = document.getElementById("appointment-submit") as HTMLButtonElement | null
  const submitLabel = document.getElementById("appointment-submit-label")
  const statusEl = document.getElementById("appointment-status")

  function showStatus(message: string, isError: boolean) {
    if (!statusEl) return
    statusEl.textContent = message
    statusEl.classList.remove("hidden", "text-brand-bright", "text-cloud")
    statusEl.classList.add(isError ? "text-brand-bright" : "text-cloud")
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault()
    if (!submitBtn || !submitLabel) return

    submitBtn.disabled = true
    submitLabel.textContent = "Sending…"

    try {
      const formData = new FormData(form)
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: { Accept: "application/json" },
        body: formData,
      })
      const result = await response.json()

      if (result.success) {
        form.reset()
        submitLabel.textContent = "Request Appointment"
        showStatus("Thanks — your request is in. We'll be in touch shortly.", false)
      } else {
        submitLabel.textContent = "Request Appointment"
        showStatus("Something went wrong. Please call or text us instead.", true)
      }
    } catch {
      submitLabel.textContent = "Request Appointment"
      showStatus("Something went wrong. Please call or text us instead.", true)
    } finally {
      submitBtn.disabled = false
    }
  })
</script>
