---
const services = [
  {
    title: "Vehicle Diagnostics & Repairs",
    body: "Full diagnostics and repairs to get you back on the road, wherever you are.",
    icon: "wrench",
  },
  {
    title: "Oil Changes & Routine Maintenance",
    body: "Keep your vehicle running strong with on-site oil changes and upkeep.",
    icon: "droplet",
  },
  {
    title: "Brake Service",
    body: "Pads, rotors, and full brake jobs done safely in your driveway.",
    icon: "disc",
  },
  {
    title: "Battery, Starter & Alternator",
    body: "Replacement and testing for the parts that keep you starting up.",
    icon: "battery",
  },
  {
    title: "Check Engine Light Diagnostics",
    body: "We read the codes and tell you what's really going on — honestly.",
    icon: "alert",
  },
  {
    title: "Lawn Mower Repair & Maintenance",
    body: "Tune-ups, blade service, and repairs to keep your yard in shape.",
    icon: "leaf",
  },
  {
    title: "Snowblower Repair",
    body: "Get ready before the storm — repairs and seasonal service.",
    icon: "snow",
  },
  {
    title: "Generator Service",
    body: "Keep your backup power dependable when you need it most.",
    icon: "power",
  },
  {
    title: "ATV & Small Engine Repairs",
    body: "From trail machines to small engines, we keep them running.",
    icon: "gauge",
  },
  {
    title: "General Troubleshooting & Repairs",
    body: "Not sure what's wrong? We'll diagnose it and get it sorted.",
    icon: "search",
  },
]

const icons: Record<string, string> = {
  wrench:
    '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  droplet: '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>',
  disc: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/>',
  battery:
    '<rect x="1" y="6" width="18" height="12" rx="2" ry="2"/><line x1="23" y1="13" x2="23" y2="11"/>',
  alert:
    '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
  leaf: '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
  snow: '<line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="2" x2="12" y2="22"/><path d="m20 16-4-4 4-4"/><path d="m4 8 4 4-4 4"/><path d="m16 4-4 4-4-4"/><path d="m8 20 4-4 4 4"/>',
  power:
    '<path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/>',
  gauge: '<path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/>',
  search:
    '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
}

const columnA = services.slice(0, 5)
const columnB = services.slice(5)
---

<section id="services" class="bg-ink py-20 text-paper sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <span class="font-display text-sm font-600 uppercase tracking-[0.3em] text-brand-bright">What We Do</span>
      <h2 class="mt-3 font-display text-4xl font-700 uppercase leading-tight tracking-tight text-balance sm:text-5xl">
        Services built around your engine — and your schedule
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-fog text-pretty">
        From daily drivers to the machines that keep your property running, we cover
        it all on-site across VT and NH.
      </p>
    </div>

    <div class="mt-14 grid gap-x-14 border-t border-white/10 lg:grid-cols-2">
      {
        [columnA, columnB].map((column) => (
          <div>
            {column.map((service) => (
              <div class="group -ml-4 flex items-start gap-5 border-b border-l-2 border-white/10 border-l-transparent py-7 pl-4 transition-colors hover:border-l-brand">
                <div class="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-brand/15 text-brand transition-colors group-hover:bg-brand group-hover:text-paper">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true" set:html={icons[service.icon]} />
                </div>
                <div>
                  <h3 class="font-display text-lg font-600 uppercase tracking-wide leading-snug">
                    {service.title}
                  </h3>
                  <p class="mt-1.5 text-sm leading-relaxed text-fog">{service.body}</p>
                </div>
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>
